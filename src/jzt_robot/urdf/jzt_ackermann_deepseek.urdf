<?xml version="1.0"?>
<robot name="jzAckermannRobot">

    <!-- ==================== 基础结构 ==================== -->
    <link name="base_footprint" />

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <!-- 底盘悬空：车轮半径 0.12m，让车轮触地，底盘底部在车轮中心高度 -->
        <origin xyz="0.0 0.0 0.12" rpy="0 0 0" />
    </joint>

    <!-- base link: 1.1m长 × 0.56m宽 × 0.32m高 -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.16" rpy="0 0 0" />
            <geometry>
                <box size="1.1 0.56 0.32" />
            </geometry>
            <material name="dark_red">
                <color rgba="0.55 0.0 0.0 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.16" rpy="0 0 0" />
            <geometry>
                <box size="1.1 0.56 0.32" />
            </geometry>
        </collision>
        <inertial>
            <mass value="15.0" />
            <inertia ixx="0.45" ixy="0" ixz="0" iyy="1.25" iyz="0" izz="1.55" />
        </inertial>
    </link>

    <gazebo reference="base_link">
        <material>Gazebo/Red</material>
    </gazebo>

    <!-- ==================== 激光雷达 ==================== -->
    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.04" />
            </geometry>
            <material name="purple">
                <color rgba="0.5 0.0 0.5 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.04" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3" />
            <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.00024" />
        </inertial>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link" />
        <child link="laser_link" />
        <!-- 前上方，高出底盘顶面 -->
        <origin xyz="0.40 0 0.36" rpy="0 0 0" />
    </joint>

    <gazebo reference="laser_link">
        <material>Gazebo/Purple</material>
    </gazebo>

    <!-- ==================== 前向相机 ==================== -->
    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.12 0.03 0.03" />
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.12 0.03 0.03" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.2" />
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002" />
        </inertial>
    </link>

    <link name="camera_optical_link"></link>

    <joint name="camera_joint" type="fixed">
        <parent link="base_link" />
        <child link="camera_link" />
        <!-- 车头正前方中央，略微嵌入车体 -->
        <origin xyz="0.56 0 0.25" rpy="0 0 0" />
    </joint>

    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera_link" />
        <child link="camera_optical_link" />
        <!-- 光学帧：Z轴朝前 -->
        <origin xyz="0.06 0 0" rpy="-1.570796 0 -1.570796" />
    </joint>

    <gazebo reference="camera_link">
        <material>Gazebo/Black</material>
        <sensor name="camera_sensor" type="camera">
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
            </camera>
            <always_on>true</always_on>
            <update_rate>30</update_rate>
            <visualize>true</visualize>
            <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
                <ros>
                    <namespace>$(arg robot_namespace)</namespace>
                    <remapping>~/image:=camera/image_raw</remapping>
                    <remapping>~/camera_info:=camera/camera_info</remapping>
                </ros>
                <camera_name>camera</camera_name>
                <frame_name>camera_optical_link</frame_name>
                <hack_baseline>0.07</hack_baseline>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ==================== IMU ==================== -->
    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
        </visual>
        <collision>
            <geometry>
                <box size="0.02 0.02 0.02" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <inertia ixx="0.000003" ixy="0" ixz="0" iyy="0.000003" iyz="0" izz="0.000003" />
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <origin xyz="0 0 0.16" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="imu_link" />
    </joint>

    <gazebo reference="imu_link">
        <material>Gazebo/Purple</material>
        <sensor name="imu_sensor" type="imu">
            <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
                <ros>
                    <namespace>$(arg robot_namespace)</namespace>
                    <remapping>~/out:=imu</remapping>
                </ros>
                <initial_orientation_as_reference>false</initial_orientation_as_reference>
                <frame_name>imu_link</frame_name>
            </plugin>
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <visualize>true</visualize>
            <imu>
                <angular_velocity>
                    <x>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>2e-4</stddev>
                            <bias_mean>0.0000075</bias_mean>
                            <bias_stddev>0.0000008</bias_stddev>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>2e-4</stddev>
                            <bias_mean>0.0000075</bias_mean>
                            <bias_stddev>0.0000008</bias_stddev>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>2e-4</stddev>
                            <bias_mean>0.0000075</bias_mean>
                            <bias_stddev>0.0000008</bias_stddev>
                        </noise>
                    </z>
                </angular_velocity>
                <linear_acceleration>
                    <x>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>1.7e-2</stddev>
                            <bias_mean>0.1</bias_mean>
                            <bias_stddev>0.001</bias_stddev>
                        </noise>
                    </x>
                    <y>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>1.7e-2</stddev>
                            <bias_mean>0.1</bias_mean>
                            <bias_stddev>0.001</bias_stddev>
                        </noise>
                    </y>
                    <z>
                        <noise type="gaussian">
                            <mean>0.0</mean>
                            <stddev>1.7e-2</stddev>
                            <bias_mean>0.1</bias_mean>
                            <bias_stddev>0.001</bias_stddev>
                        </noise>
                    </z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- ==================== 后轮（驱动轮） ==================== -->

    <link name="steering_drive_link">
        <inertial>
            <mass value="0.1" />
            <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
        </inertial>
    </link>
    <link name="left_rear_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="dark_grey">
                <color rgba="0.3 0.3 0.3 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0054" />
        </inertial>
    </link>

    <link name="right_rear_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="dark_grey">
                <color rgba="0.3 0.3 0.3 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0054" />
        </inertial>
    </link>

    <!-- ==================== 前轮（转向+驱动） ==================== -->
    <link name="front_left_steer_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.04 0.03 0.03" />
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.001 0.001 0.001" />
            </geometry>   <!-- 极小，防止干涉 -->
        </collision>
        <inertial>
            <mass value="0.5" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
        </inertial>
    </link>

    <link name="front_right_steer_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.04 0.03 0.03" />
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.001 0.001 0.001" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.5" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
        </inertial>
    </link>

    <link name="left_front_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="dark_grey">
                <color rgba="0.3 0.3 0.3 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0054" />
        </inertial>
    </link>

    <link name="right_front_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="dark_grey">
                <color rgba="0.3 0.3 0.3 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.57079 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.0054" />
        </inertial>
    </link>

    <joint name="steering_joint" type="revolute">
        <parent link="base_link" />
        <child link="steering_drive_link" />
        <origin xyz="0.4 0 0" rpy="0 0 0" /> <!-- 放在前轴中心 -->
        <axis xyz="0 0 1" />
        <limit lower="-0.5236" upper="0.5236" effort="100" velocity="3.0" />
        <dynamics damping="0.1" friction="0.01" />
    </joint>

    <!-- 转向关节 -->
    <joint name="front_left_steer_joint" type="revolute">
        <parent link="base_link" />
        <child link="front_left_steer_link" />
        <origin xyz="0.40 0.28 0" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit lower="-0.523598" upper="0.523598" effort="100" velocity="3.0" />
        <dynamics damping="0.05" friction="0.01" />
    </joint>

    <joint name="front_right_steer_joint" type="revolute">
        <parent link="base_link" />
        <child link="front_right_steer_link" />
        <origin xyz="0.40 -0.28 0" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit lower="-0.523598" upper="0.523598" effort="100" velocity="3.0" />
        <dynamics damping="0.05" friction="0.01" />
    </joint>

    <!-- 后轮驱动关节 -->
    <joint name="left_rear_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_rear_wheel_link" />
        <origin xyz="-0.40 0.28 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="right_rear_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_rear_wheel_link" />
        <origin xyz="-0.40 -0.28 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- 前轮旋转关节 -->
    <joint name="left_front_wheel_joint" type="continuous">
        <parent link="front_left_steer_link" />
        <child link="left_front_wheel_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="right_front_wheel_joint" type="continuous">
        <parent link="front_right_steer_link" />
        <child link="right_front_wheel_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- ==================== 车轮摩擦 ==================== -->
    <gazebo reference="left_rear_wheel_link">
        <material>Gazebo/DarkGrey</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu1>10.0</mu1>       <!-- 纵向（滚动方向）摩擦 -->
                        <mu2>10.0</mu2>     <!-- 侧向摩擦 -->
                        <fdir1>1 0 0</fdir1>
                        <kp value="10000000.0" />
                        <kd value="1.0" />
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e8</kp>        <!-- 接触刚度增大 -->
                        <kd>1.0</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
                <bounce>
                    <restitution_coefficient>0.0</restitution_coefficient>
                </bounce>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="right_rear_wheel_link">
        <material>Gazebo/DarkGrey</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu1>10.0</mu1>
                        <mu2>10.0</mu2>
                        <fdir1>1 0 0</fdir1>
                        <kp value="10000000.0" />
                        <kd value="1.0" />
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e8</kp>
                        <kd>1.0</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
                <bounce>
                    <restitution_coefficient>0.0</restitution_coefficient>
                </bounce>
            </surface>
        </collision>
    </gazebo>

    <!-- 前轮：侧向摩擦降低，允许转向时滑动 -->
    <gazebo reference="left_front_wheel_link">
        <material>Gazebo/DarkGrey</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu1>10.0</mu1>       <!-- 纵向高摩擦，保证驱动 -->
                        <mu2>0.5</mu2>      <!-- 侧向降低，允许转向滑动 -->
                        <fdir1>1 0 0</fdir1>
                        <kp value="10000000.0" />
                        <kd value="1.0" />
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e8</kp>
                        <kd>1.0</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
                <bounce>
                    <restitution_coefficient>0.0</restitution_coefficient>
                </bounce>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="right_front_wheel_link">
        <material>Gazebo/DarkGrey</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu1>10.0</mu1>
                        <mu2>0.5</mu2>
                        <kp value="10000000.0" />
                        <kd value="1.0" />
                        <fdir1>1 0 0</fdir1>
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>1e8</kp>
                        <kd>1.0</kd>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
                <bounce>
                    <restitution_coefficient>0.0</restitution_coefficient>
                </bounce>
            </surface>
        </collision>
    </gazebo>

    <!-- ==================== 阿克曼驱动插件 ==================== -->
    <gazebo>
        <plugin name="ackermann_drive" filename="libgazebo_ros_ackermann_drive.so">
            <ros>
                <namespace>$(arg robot_namespace)</namespace>
                <remapping>cmd_vel:=cmd_vel</remapping>
                <remapping>odom:=odom</remapping>
            </ros>
            <update_rate>100</update_rate>

            <!-- 转向关节 -->
            <left_steering_joint>front_left_steer_joint</left_steering_joint>
            <right_steering_joint>front_right_steer_joint</right_steering_joint>
            <!-- 旧版必需的 steering_wheel_joint，指向任意转向关节 -->
            <!-- <steering_wheel_joint>front_left_steer_joint</steering_wheel_joint> -->

            <!-- 前轮驱动关节 -->
            <front_left_joint>left_front_wheel_joint</front_left_joint>
            <front_right_joint>right_front_wheel_joint</front_right_joint>
            <!-- 后轮驱动关节 -->
            <rear_left_joint>left_rear_wheel_joint</rear_left_joint>
            <rear_right_joint>right_rear_wheel_joint</rear_right_joint>
            <left_joint>left_rear_wheel_joint</left_joint>
            <right_joint>right_rear_wheel_joint</right_joint>

            <!-- 转向 PID 参数（旧版强制要求） -->
            <!-- <left_steering_pid_gain>10.0 0.0 1.0</left_steering_pid_gain>
            <right_steering_pid_gain>10.0 0.0 1.0</right_steering_pid_gain>
            <left_steering_i_range>0 0</left_steering_i_range>
            <right_steering_i_range>0 0</right_steering_i_range> -->

            <!-- 运动学 -->
            <wheel_separation>0.56</wheel_separation>
            <wheel_base>0.80</wheel_base>
            <wheel_diameter>0.24</wheel_diameter>
            <wheel_width>0.08</wheel_width>

            <!-- 力矩与速度 -->
            <max_wheel_torque>2000</max_wheel_torque>
            <max_wheel_acceleration>50.0</max_wheel_acceleration>
            <max_steer>0.523598</max_steer>
            <max_speed>3.0</max_speed>
            <steering_speed>3.0</steering_speed>

            <!-- 输出 -->
            <publish_odom>true</publish_odom>
            <publish_odom_tf>false</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
            <publish_steerangle>true</publish_steerangle>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
        </plugin>
    </gazebo>

    <!-- ==================== 激光雷达插件 ==================== -->
    <gazebo reference="laser_link">
        <material>Gazebo/Purple</material>
        <sensor name="laser_sensor" type="ray">
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>20</update_rate>
            <pose>0 0 0 0 0 0</pose>
            <ray>
                <scan>
                    <horizontal>
                        <samples>720</samples>
                        <resolution>1.0</resolution>
                        <time_increment>0.000069</time_increment>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.15</min>
                    <max>15.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.001</stddev>
                </noise>
            </ray>
            <plugin name="gazebo_ros_head_laser_controller" filename="libgazebo_ros_ray_sensor.so">
                <ros>
                    <namespace>$(arg robot_namespace)</namespace>
                    <remapping>~/out:=scan</remapping>
                </ros>
                <topicName>scan</topicName>
                <frameName>laser_link</frameName>
                <frame_name>laser_link</frame_name>
                <output_type>sensor_msgs/LaserScan</output_type>
                <min_range>0.15</min_range>
                <max_range>15.0</max_range>
                <angle_min>-3.14159</angle_min>
                <angle_max>3.14159</angle_max>
                <scan_time>0.05</scan_time>
            </plugin>
        </sensor>
    </gazebo>

    <!-- ==================== 物理引擎 ==================== -->
    <gazebo>
        <physics type="ode">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
            <real_time_update_rate>1000</real_time_update_rate>
        </physics>
    </gazebo>

    <gazebo>
        <plugin name="gazebo_ros_joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
            <ros>
                <namespace>$(arg robot_namespace)</namespace>
                <remapping>~/out:=joint_states</remapping>
            </ros>
            <update_rate>100</update_rate>
            <joint_name>front_left_steer_joint</joint_name>
            <joint_name>front_right_steer_joint</joint_name>
            <joint_name>left_front_wheel_joint</joint_name>
            <joint_name>right_front_wheel_joint</joint_name>
            <joint_name>left_rear_wheel_joint</joint_name>
            <joint_name>right_rear_wheel_joint</joint_name>
        </plugin>
    </gazebo>

</robot>
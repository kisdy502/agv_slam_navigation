  <!-- ==================== 右前方雷达 ==================== -->
<link name="laser_front_right_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <cylinder length="0.02" radius="0.02" />
    </geometry>
    <material name="dark_red">
      <color rgba="0.8 0.0 0.0 1.0" />
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <cylinder length="0.002" radius="0.002" />
    </geometry>
  </collision>
  <inertial>
    <mass value="0.1" />
    <inertia ixx="0.000190416666667" ixy="0" ixz="0" iyy="0.0001904" iyz="0" izz="0.00036" />
  </inertial>
</link>

<!-- 右前方雷达安装：车体右前方，朝右前方 -->
<joint name="laser_front_right_joint" type="fixed">
  <parent link="base_link" />
  <child link="laser_front_right_link" />
  <!-- 
      车体尺寸 0.6(x) × 0.4(y) × 0.12(z)
      右前方：x=+0.28(靠前), y=-0.15(靠右), z=0.07(顶部下方5cm)
      朝向：270°扫描，中心线朝右前方45°，即绕Z轴旋转 -45°(或 315°)
    -->
  <origin xyz="0.28 -0.15 0.07" rpy="0 0 -0.785398" />
</joint>

<!-- 右前方雷达 Gazebo 传感器 -->
<gazebo reference="laser_front_right_link">
  <material>Gazebo/Red</material>
  <sensor name="laser_front_right_sensor" type="ray">
    <always_on>true</always_on>
    <visualize>true</visualize>
    <update_rate>20</update_rate>
    <pose>0 0 0 0 0 0</pose>

    <ray>
      <scan>
        <horizontal>
          <samples>540</samples>          <!-- 270° × 2点/度 = 540 -->
          <resolution>1.0</resolution>
          <time_increment>0.0000926</time_increment>  <!-- 1/20/540 -->
          <!-- 270° = ±135° = ±2.35619 rad -->
          <min_angle>-2.35619</min_angle>
          <max_angle>2.35619</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.15</min>
        <max>45.0</max>
        <resolution>0.01</resolution>
      </range>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </ray>

    <plugin name="gazebo_ros_laser_front_right" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=scan_front_right</remapping>
      </ros>
      <topicName>scan_front_right</topicName>
      <frameName>laser_front_right_link</frameName>
      <frame_name>laser_front_right_link</frame_name>
      <output_type>sensor_msgs/LaserScan</output_type>
      <min_range>0.15</min_range>
      <max_range>45.0</max_range>
      <angle_min>-2.35619</angle_min>
      <angle_max>2.35619</angle_max>
      <scan_time>0.05</scan_time>
    </plugin>
  </sensor>
</gazebo>


<!-- ==================== 左后方雷达 ==================== -->
<link name="laser_rear_left_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <cylinder length="0.02" radius="0.02" />
    </geometry>
    <material name="dark_red">
      <color rgba="0.8 0.0 0.0 1.0" />
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0" />
    <geometry>
      <cylinder length="0.002" radius="0.002" />
    </geometry>
  </collision>
  <inertial>
    <mass value="0.1" />
    <inertia ixx="0.000190416666667" ixy="0" ixz="0" iyy="0.0001904" iyz="0" izz="0.00036" />
  </inertial>
</link>

<!-- 左后方雷达安装：车体左后方，朝左后方 -->
<joint name="laser_rear_left_joint" type="fixed">
  <parent link="base_link" />
  <child link="laser_rear_left_link" />
  <!-- 
      左后方：x=-0.28(靠后), y=+0.15(靠左), z=0.07
      朝向：朝左后方225°，即绕Z轴旋转 2.35619 rad (135°)
      注意：雷达本体坐标系X轴朝前，所以要转135°让它朝左后
    -->
  <origin xyz="-0.28 0.15 0.07" rpy="0 0 2.35619" />
</joint>

<!-- 左后方雷达 Gazebo 传感器 -->
<gazebo reference="laser_rear_left_link">
  <material>Gazebo/Red</material>
  <sensor name="laser_rear_left_sensor" type="ray">
    <always_on>true</always_on>
    <visualize>true</visualize>
    <update_rate>20</update_rate>
    <pose>0 0 0 0 0 0</pose>

    <ray>
      <scan>
        <horizontal>
          <samples>540</samples>
          <resolution>1.0</resolution>
          <time_increment>0.0000926</time_increment>
          <min_angle>-2.35619</min_angle>
          <max_angle>2.35619</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.15</min>
        <max>45.0</max>
        <resolution>0.01</resolution>
      </range>
      <noise>
        <type>gaussian</type>
        <mean>0.0</mean>
        <stddev>0.01</stddev>
      </noise>
    </ray>

    <plugin name="gazebo_ros_laser_rear_left" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <namespace>/</namespace>
        <remapping>~/out:=scan_rear_left</remapping>
      </ros>
      <topicName>scan_rear_left</topicName>
      <frameName>laser_rear_left_link</frameName>
      <frame_name>laser_rear_left_link</frame_name>
      <output_type>sensor_msgs/LaserScan</output_type>
      <min_range>0.15</min_range>
      <max_range>45.0</max_range>
      <angle_min>-2.35619</angle_min>
      <angle_max>2.35619</angle_max>
      <scan_time>0.05</scan_time>
    </plugin>
  </sensor>
</gazebo>
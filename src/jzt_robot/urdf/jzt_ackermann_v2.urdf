<?xml version="1.0"?>
<robot name="ackermann_robot">

    <!-- 基础底盘 -->
    <link name="base_footprint" />

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0.0 0.0 0.12" rpy="0 0 0" />
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.16" rpy="0 0 0" />
            <geometry>
                <box size="1.1 0.56 0.32" />
            </geometry>
            <material name="robot_base">
                <color rgba="0.3 0.3 0.8 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0.16" rpy="0 0 0" />
            <geometry>
                <box size="1.1 0.56 0.32" />
            </geometry>
        </collision>
        <inertial>
            <mass value="20.0" />
            <inertia ixx="0.8" ixy="0" ixz="0" iyy="1.5" iyz="0" izz="2.0" />
        </inertial>
    </link>

    <!-- 阿克曼转向连杆 -->
    <link name="front_axle_center_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.1" radius="0.05" />
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.1" radius="0.05" />
            </geometry>
        </collision>
        <inertial>
            <mass value="2.0" />
            <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.02" />
        </inertial>
    </link>

    <!-- 阿克曼转向关节 -->
    <joint name="front_axle_steer_joint" type="continuous">
        <parent link="base_link" />
        <child link="front_axle_center_link" />
        <origin xyz="0.40 0 0.0" rpy="0 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <!-- 前轮转向连杆 -->
    <link name="front_left_steer_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.02 0.05" />
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.02 0.05" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
        </inertial>
    </link>

    <link name="front_right_steer_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.02 0.05" />
            </geometry>
            <material name="grey">
                <color rgba="0.7 0.7 0.7 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.02 0.05" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
        </inertial>
    </link>

    <!-- 转向连杆关节 -->
    <joint name="front_left_steer_joint" type="revolute">
        <parent link="front_axle_center_link" />
        <child link="front_left_steer_link" />
        <origin xyz="0 0.28 0" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit lower="-0.785" upper="0.785" effort="200" velocity="4.0" />
        <dynamics damping="0.2" friction="0.1" />
    </joint>

    <joint name="front_right_steer_joint" type="revolute">
        <parent link="front_axle_center_link" />
        <child link="front_right_steer_link" />
        <origin xyz="0 -0.28 0" rpy="0 0 0" />
        <axis xyz="0 0 1" />
        <limit lower="-0.785" upper="0.785" effort="200" velocity="4.0" />
        <dynamics damping="0.2" friction="0.1" />
    </joint>

    <!-- 车轮 -->
    <link name="left_rear_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02" />
        </inertial>
    </link>

    <link name="right_rear_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02" />
        </inertial>
    </link>

    <link name="left_front_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02" />
        </inertial>
    </link>

    <link name="right_front_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1.0" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <geometry>
                <cylinder length="0.08" radius="0.12" />
            </geometry>
        </collision>
        <inertial>
            <mass value="1.5" />
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02" />
        </inertial>
    </link>

    <!-- 后轮驱动关节 -->
    <joint name="left_rear_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_rear_wheel_link" />
        <origin xyz="-0.40 0.28 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="right_rear_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_rear_wheel_link" />
        <origin xyz="-0.40 -0.28 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- 前轮驱动关节 -->
    <joint name="left_front_wheel_joint" type="continuous">
        <parent link="front_left_steer_link" />
        <child link="left_front_wheel_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="right_front_wheel_joint" type="continuous">
        <parent link="front_right_steer_link" />
        <child link="right_front_wheel_link" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <!-- 阿克曼控制插件 -->
    <gazebo>
        <plugin name="ackermann_steering_controller" filename="libgazebo_ros_ackermann_steering.so">
            <ros>
                <namespace>/ackermann</namespace>
            </ros>
            <update_rate>100.0</update_rate>
            <robot_base_frame>base_footprint</robot_base_frame>
            
            <!-- 转向关节 -->
            <left_steering_joint>front_left_steer_joint</left_steering_joint>
            <right_steering_joint>front_right_steer_joint</right_steering_joint>
            
            <!-- 驱动关节 -->
            <front_left_wheel_joint>left_front_wheel_joint</front_left_wheel_joint>
            <front_right_wheel_joint>right_front_wheel_joint</front_right_wheel_joint>
            <rear_left_wheel_joint>left_rear_wheel_joint</rear_left_wheel_joint>
            <rear_right_wheel_joint>right_rear_wheel_joint</rear_right_wheel_joint>
            
            <!-- 转向PID控制参数 -->
            <steering_pid_gain_p>1000.0</steering_pid_gain_p>
            <steering_pid_gain_i>0.0</steering_pid_gain_i>
            <steering_pid_gain_d>10.0</steering_pid_gain_d>
            <steering_pid_limit_min>-1000.0</steering_pid_limit_min>
            <steering_pid_limit_max>1000.0</steering_pid_limit_max>
            
            <!-- 驱动PID控制参数 -->
            <drive_pid_gain_p>100.0</drive_pid_gain_p>
            <drive_pid_gain_i>0.0</drive_pid_gain_i>
            <drive_pid_gain_d>1.0</drive_pid_gain_d>
            <drive_pid_limit_min>-1000.0</drive_pid_limit_min>
            <drive_pid_limit_max>1000.0</drive_pid_limit_max>
            
            <!-- 运动学参数 -->
            <wheel_separation>0.56</wheel_separation>
            <wheel_base>0.80</wheel_base>
            <wheel_radius>0.12</wheel_radius>
            
            <!-- 阿克曼参数 -->
            <ackermann>true</ackermann>
            <max_steer_angle>0.785</max_steer_angle>
            <max_speed>2.0</max_speed>
            <max_acceleration>1.0</max_acceleration>
            
            <!-- 控制话题 -->
            <command_topic>cmd_vel</command_topic>
            <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            
            <!-- 发布TF -->
            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
        </plugin>
    </gazebo>

    <!-- 车轮摩擦配置 -->
    <gazebo reference="left_rear_wheel_link">
        <material>Gazebo/Black</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.8</mu>
                        <mu2>0.8</mu2>
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="right_rear_wheel_link">
        <material>Gazebo/Black</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.8</mu>
                        <mu2>0.8</mu2>
                        <slip1>0.0</slip1>
                        <slip2>0.0</slip2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="left_front_wheel_link">
        <material>Gazebo/Black</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.8</mu>
                        <mu2>0.4</mu2> <!-- 侧向摩擦降低，便于转向 -->
                        <slip1>0.0</slip1>
                        <slip2>0.1</slip2> <!-- 允许轻微滑动 -->
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="right_front_wheel_link">
        <material>Gazebo/Black</material>
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>0.8</mu>
                        <mu2>0.4</mu2>
                        <slip1>0.0</slip1>
                        <slip2>0.1</slip2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

</robot>
